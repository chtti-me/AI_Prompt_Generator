# AI Prompt Generator Platform - 環境變數配置範本
# 複製此檔案為 .env 並填入您的實際值

# =============================================================================
# Flask 應用配置
# =============================================================================
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# 伺服器配置
HOST=0.0.0.0
PORT=5001

# =============================================================================
# AI 服務配置（二選一或兩者都配置）
# =============================================================================

# OpenAI API（選項 A）
# 獲取位置: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini API（選項 B）
# 獲取位置: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# AI 服務偏好設定
# 可選值: openai, gemini, both
AI_PROVIDER=both
# 預設使用哪個服務（當 AI_PROVIDER=both 時）
DEFAULT_AI_PROVIDER=gemini

# =============================================================================
# RAG 知識庫配置
# =============================================================================

# 向量資料庫類型
# 可選值: chromadb, faiss
VECTOR_DB_TYPE=chromadb

# ChromaDB 配置
CHROMA_PERSIST_DIRECTORY=./data/vector_store
CHROMA_COLLECTION_NAME=prompt_library

# 嵌入模型配置
# 可選值: openai, sentence-transformers
EMBEDDING_PROVIDER=sentence-transformers
SENTENCE_TRANSFORMER_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# RAG 檢索參數
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# =============================================================================
# Google Sheets 整合（可選）
# =============================================================================

# Google Sheets 啟用開關
GOOGLE_SHEETS_ENABLED=false

# Google Service Account JSON 檔案路徑
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service_account.json

# Google Sheets ID
PROMPTS_SHEET_ID=your-google-sheet-id-here
HISTORY_SHEET_ID=your-history-sheet-id-here

# 自動同步設定
AUTO_SYNC_TO_SHEETS=false
SYNC_INTERVAL_MINUTES=30

# =============================================================================
# 資料庫配置
# =============================================================================

# SQLite 資料庫路徑
DATABASE_URL=sqlite:///./data/prompts.db

# =============================================================================
# 檔案上傳配置
# =============================================================================

# 上傳目錄
UPLOAD_FOLDER=./data/uploads

# 允許的檔案類型
ALLOWED_EXTENSIONS=txt,md,pdf,docx

# 最大檔案大小（MB）
MAX_FILE_SIZE_MB=10

# =============================================================================
# 應用功能開關
# =============================================================================

# 啟用 RAG 功能
ENABLE_RAG=true

# 啟用 AI 優化功能
ENABLE_AI_OPTIMIZATION=true

# 啟用使用統計
ENABLE_ANALYTICS=true

# 啟用匯出功能
ENABLE_EXPORT=true

# =============================================================================
# 日誌配置
# =============================================================================

LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# =============================================================================
# 安全配置
# =============================================================================

# CORS 允許的來源（生產環境請設定具體網域）
CORS_ORIGINS=*

# API 速率限制（每分鐘請求數）
RATE_LIMIT_PER_MINUTE=60

# Session 過期時間（分鐘）
SESSION_TIMEOUT_MINUTES=60
